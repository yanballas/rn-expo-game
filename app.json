{
    "expo": {
        "name": "rn-expo-game",
        "slug": "rn-expo-game",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./client/assets/images/icon.png",
        "scheme": "rnexpogame",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./client/assets/images/android-icon-foreground.png",
                "backgroundImage": "./client/assets/images/android-icon-background.png",
                "monochromeImage": "./client/assets/images/android-icon-monochrome.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false
        },
        "web": {
            "output": "static",
            "favicon": "./client/assets/images/favicon.png"
        },
        "plugins": [
            ["expo-router", { "root": "./client/app" }],
            [
                "expo-splash-screen",
                {
                    "image": "./client/assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        }
    }
}
