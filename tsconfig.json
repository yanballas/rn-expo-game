{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@assets/*": ["./client/assets/*"],
            "@components/*": ["./client/components/*"],
            "@store/*": ["./client/store/*"],
            "@storage/*": ["./client/storage/*"]
        }
    },
    "include": [
        "client/**/*.ts",
        "client/**/*.tsx",
        "utils/**/*.ts",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}
