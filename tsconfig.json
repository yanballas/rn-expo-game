{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@utils/client/*": [
        "./client/utils/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@assets/*": [
        "./client/assets/*"
      ],
      "@components/*": [
        "./client/components/*"
      ],
      "@store/*": [
        "./client/store/*"
      ],
      "@storage/*": [
        "./client/storage/*"
      ]
    }
  },
  "include": [
    "client/**/*.ts",
    "client/**/*.tsx",
    "client/**/*.d.ts",
    "utils/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
